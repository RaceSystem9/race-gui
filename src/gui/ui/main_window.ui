       <property name="styleSheet">
        <string notr="true">/* 기본 상태 */
QPushButton {
    border: 1px solid #a0a0a0;
    border-radius: 4px;
    background-color: #f5f5f5;
}

/* 마우스를 올렸을 때 (Hover) */
QPushButton:hover {
    border: 1px solid #3498db; /* 테두리를 파란색으로 변경 */
    background-color: #e8f4fc; /* 배경색도 살짝 밝은 파란빛으로 변경 */
}

/* 버튼을 클릭하고 있을 때 (Pressed) */
QPushButton:pressed {
    border: 1px solid #2980b9; /* 진한 파란색 테두리 */
    background-color: #d4e6f1; /* 조금 더 어두운 배경색 */
}
</string>
       </property>
       <property name="text">
